{
  "uid": "ai-incident-overview",
  "title": "AI Incident Copilot Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests by Service",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (http_requests_total)",
          "legendFormat": "{{service}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Rate by Service",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Average Latency by Service",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_request_duration_seconds_sum[1m])) / sum by (service) (rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Error Count by Service",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (service) (http_request_errors_total)",
          "legendFormat": "{{service}}"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    }
  ]
}
